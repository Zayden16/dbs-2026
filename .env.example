# DBS Project — Railway Cloud Credentials (template)
# Copy to .env and fill in real values. .env is gitignored.

# --- MySQL (Railway) ---
MYSQL_HOST=your-mysql-host.proxy.rlwy.net
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=ev_project
MYSQL_URI=mysql://root:your-mysql-password@your-mysql-host.proxy.rlwy.net:3306/ev_project

# --- MongoDB (Railway) ---
MONGO_HOST=your-mongo-host.proxy.rlwy.net
MONGO_PORT=27017
MONGO_USER=mongo
MONGO_PASSWORD=your-mongo-password
MONGO_URI=mongodb://mongo:your-mongo-password@your-mongo-host.proxy.rlwy.net:27017

# --- Metabase ---
METABASE_URL=https://your-metabase-instance.up.railway.app
METABASE_EMAIL=you@example.com
METABASE_PASSWORD=your-metabase-password
